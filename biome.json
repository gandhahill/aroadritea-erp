{
  "$schema": "https://biomejs.dev/schemas/1.9.0/schema.json",
  "organizeImports": {
    "enabled": true
  },
  "linter": {
    "enabled": true,
    "rules": {
      "recommended": true,
      "suspicious": {
        "noExplicitAny": "warn",
        "noConsoleLog": "warn",
        "noAssignInExpressions": "warn",
        "noGlobalIsNan": "warn",
        "noDoubleEquals": "warn",
        "noThenProperty": "warn",
        "noArrayIndexKey": "warn",
        "noImplicitAnyLet": "warn"
      },
      "complexity": {
        "noForEach": "off",
        "useLiteralKeys": "warn",
        "noThisInStatic": "warn",
        "noUselessFragments": "warn",
        "noUselessCatch": "warn",
        "noUselessSwitchCase": "warn"
      },
      "style": {
        "noNonNullAssertion": "warn",
        "noCommaOperator": "warn",
        "useSingleVarDeclarator": "warn",
        "useTemplate": "warn",
        "noVar": "warn",
        "noUnusedTemplateLiteral": "warn",
        "noParameterAssign": "warn",
        "useSelfClosingElements": "warn",
        "useExponentiationOperator": "warn",
        "useNodejsImportProtocol": "warn",
        "noUselessElse": "warn"
      },
      "a11y": {
        "useButtonType": "warn",
        "noSvgWithoutTitle": "warn",
        "noLabelWithoutControl": "warn",
        "useKeyWithClickEvents": "warn",
        "noAutofocus": "warn"
      },
      "performance": {
        "noDelete": "warn"
      },
      "correctness": {
        "useExhaustiveDependencies": "warn"
      }
    }
  },
  "formatter": {
    "enabled": true,
    "indentStyle": "space",
    "indentWidth": 2,
    "lineWidth": 100
  },
  "javascript": {
    "formatter": {
      "quoteStyle": "single",
      "semicolons": "always",
      "trailingCommas": "all"
    }
  },
  "files": {
    "ignore": [
      "node_modules",
      ".next",
      "dist",
      "out",
      "coverage",
      ".agents",
      ".antigravitycli",
      ".claude",
      "packages/db/migrations/meta",
      "*.min.js",
      "apps/web/public/sw.js"
    ]
  }
}
