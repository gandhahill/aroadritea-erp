# Caddyfile — Aroadri Tea ERP
# SD §32.3 — Domain routing + auto TLS (Let's Encrypt)
# SD §32.2 — DNS: A record @ → VPS IP; CNAME erp, mcp → @

{
    email admin@aroadritea.com
}

# ── Public Website ─────────────────────────────────────────────────────────
aroadritea.com, www.aroadritea.com {
    encode zstd gzip

    # Member portal routes — no cache (session-dependent)
    @member path /api/member/* /id/member/* /en/member/* /zh/member/*
    header @member Cache-Control "no-store"

    # Static assets — long-term immutable cache
    header /assets/* Cache-Control "public, max-age=31536000, immutable"
    header /_next/static/* Cache-Control "public, max-age=31536000, immutable"

    reverse_proxy site:3000
}

# ── ERP Web App ────────────────────────────────────────────────────────────
erp.aroadritea.com {
    encode zstd gzip

    # Static assets
    header /_next/static/* Cache-Control "public, max-age=31536000, immutable"

    reverse_proxy web:3001
}

# ── MCP Server ─────────────────────────────────────────────────────────────
mcp.erp.aroadritea.com {
    encode zstd gzip

    reverse_proxy mcp:3002
}
