# syntax=docker/dockerfile:1.7

# ── Stage 1: Install dependencies ─────────────────────────────────────────────
FROM node:22-alpine AS deps
WORKDIR /app
RUN corepack enable pnpm
COPY package.json pnpm-lock.yaml pnpm-workspace.yaml ./
COPY packages ./packages
COPY apps/mcp/package.json ./apps/mcp/
RUN pnpm install --frozen-lockfile

# ── Stage 2: Build (compile TypeScript to JS) ──────────────────────────────────
FROM node:22-alpine AS builder
WORKDIR /app
RUN corepack enable pnpm
COPY --from=deps /app/node_modules ./node_modules
COPY --from=deps /app/packages ./packages
COPY --from=deps /app/apps/mcp/node_modules ./apps/mcp/node_modules
COPY . .
WORKDIR /app/apps/mcp
RUN pnpm build

# ── Stage 3: Runtime ──────────────────────────────────────────────────────────
FROM node:22-alpine AS runner
WORKDIR /app

ENV NODE_ENV=production
ENV PORT=3002

# SD §4.3: apps/mcp hard limit 192 MB → max-old-space-size=150
ENV NODE_OPTIONS="--max-old-space-size=150"

RUN addgroup --system --gid 1001 nodejs && \
    adduser --system --uid 1001 mcpuser

COPY --from=deps --chown=mcpuser:nodejs /app/node_modules /app/node_modules
COPY --from=builder --chown=mcpuser:nodejs /app/packages /app/packages
COPY --from=deps --chown=mcpuser:nodejs /app/apps/mcp/node_modules /app/apps/mcp/node_modules
COPY --from=builder --chown=mcpuser:nodejs /app/apps/mcp/package.json /app/apps/mcp/package.json
COPY --from=builder --chown=mcpuser:nodejs /app/apps/mcp/src /app/apps/mcp/src

WORKDIR /app/apps/mcp

USER mcpuser
EXPOSE 3002

HEALTHCHECK --interval=30s --timeout=5s --start-period=10s --retries=3 \
  CMD wget --no-verbose --tries=1 --spider http://localhost:3002/healthz || exit 1

CMD ["node", "--import", "tsx", "src/server.ts"]
