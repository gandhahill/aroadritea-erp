{
  "name": "@erp/root",
  "version": "0.0.0",
  "private": true,
  "packageManager": "pnpm@9.15.4",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev": "pnpm -r --parallel dev",
    "build": "pnpm -r build",
    "typecheck": "pnpm -r typecheck",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "test": "pnpm -r test",
    "db:generate": "pnpm --filter @erp/db generate",
    "db:migrate": "pnpm --filter @erp/db migrate",
    "db:seed": "pnpm --filter @erp/db seed",
    "seed:naixer": "tsx scripts/seed-naixer-codes.ts"
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.0",
    "typescript": "^5.5.0"
  }
}
