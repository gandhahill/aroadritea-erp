{
  "name": "@erp/root",
  "version": "0.0.0",
  "private": true,
  "packageManager": "pnpm@9.15.4",
  "engines": {
    "node": ">=20"
  },
  "pnpm": {
    "overrides": {
      "esbuild": "0.28.0",
      "hono": "4.12.18",
      "ip-address": "10.1.1",
      "next": "15.5.18",
      "postcss": "8.5.14"
    }
  },
  "scripts": {
    "dev": "pnpm -r --parallel dev",
    "build": "pnpm -r build",
    "typecheck": "pnpm -r typecheck",
    "lint": "biome check . --max-diagnostics=1000",
    "lint:fix": "biome check --write . --max-diagnostics=1000",
    "test": "pnpm -r test",
    "pm2:start": "pm2 start ecosystem.config.cjs --env production",
    "pm2:reload": "pm2 reload ecosystem.config.cjs --env production --update-env",
    "pm2:restart": "pm2 restart ecosystem.config.cjs --env production --update-env",
    "pm2:stop": "pm2 stop ecosystem.config.cjs",
    "pm2:logs": "pm2 logs",
    "pm2:status": "pm2 status",
    "db:generate": "pnpm --filter @erp/db generate",
    "db:migrate": "pnpm --filter @erp/db migrate",
    "db:seed": "pnpm --filter @erp/db seed",
    "seed:menu": "tsx scripts/seed-aroadri-menu.ts",
    "seed:naixer": "tsx scripts/seed-naixer-codes.ts"
  },
  "dependencies": {
    "tsx": "^4.21.0"
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.0",
    "typescript": "^5.5.0"
  }
}
