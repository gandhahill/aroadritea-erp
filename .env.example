# Database (Neon PostgreSQL)
DATABASE_URL=postgresql://user:password@host/dbname?sslmode=require

# Auth (better-auth)
BETTER_AUTH_SECRET=your-secret-here
BETTER_AUTH_URL=http://localhost:3000

# Optional one-time bootstrap admin. Leave password empty unless creating the first admin.
SEED_ADMIN_EMAIL=admin@aroadritea.com
SEED_ADMIN_PASSWORD=
SEED_ADMIN_NAME="Aroadri Admin"

# Public member registration
NEXT_PUBLIC_TURNSTILE_SITE_KEY=
TURNSTILE_SECRET_KEY=
PII_ENCRYPTION_KEY=change-me-32-byte-random-secret

# Automatic email via HestiaCP mailbox SMTP
SMTP_HOST=mail.aroadritea.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=noreply@aroadritea.com
SMTP_PASS=
SMTP_FROM=noreply@aroadritea.com
SMTP_FROM_NAME="Aroadri Tea"

# App URLs
NEXT_PUBLIC_WEB_URL=http://localhost:3000
NEXT_PUBLIC_SITE_URL=http://localhost:3001
MCP_SERVER_URL=http://localhost:3002
NEXT_PUBLIC_PRINT_BRIDGE_URL=http://127.0.0.1:7913

# BinderByte shipment tracking (500 request/month plan guard is enforced in app)
BINDERBYTE_API_KEY=

# Persistent local uploads for product images and attachments
UPLOAD_STORAGE_DIR=storage/uploads

# Optional worker health monitor overrides. Docker defaults use service DNS.
SITE_HEALTH_URL=http://site:3000/api/healthz
WEB_HEALTH_URL=http://web:3001/api/healthz
MCP_HEALTH_URL=http://mcp:3002/healthz

# AI Assistant — secrets only. Non-secret runtime settings are managed
# from ERP UI: Settings -> AI Assistant.
DEEPSEEK_API_KEY=

# Optional AI web search (Exa). Per-session opt-in via the chat
# session's "Izinkan pencarian web" checkbox. Leave empty to disable
# the tool entirely (the model never sees it exists).
# Get a key at https://dashboard.exa.ai/api-keys
EXA_SEARCH_API_KEY=

# Node environment
NODE_ENV=development
