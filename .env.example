# Database (Neon PostgreSQL)
DATABASE_URL=postgresql://user:password@host/dbname?sslmode=require

# Auth (better-auth)
BETTER_AUTH_SECRET=your-secret-here
BETTER_AUTH_URL=http://localhost:3000

# Public member registration
NEXT_PUBLIC_TURNSTILE_SITE_KEY=
TURNSTILE_SECRET_KEY=
RESEND_API_KEY=
MEMBER_OTP_FROM_EMAIL="Aroadri Tea <member@aroadritea.com>"

# POS posting defaults. Production may override without source edits.
# Tax rate itself is read from tax_rates by code.
POS_PB1_TAX_CODE=PB1
POS_CASH_ACCOUNT_CODE=1-1030
POS_REVENUE_ACCOUNT_CODE=4-1010
POS_DONATION_TRUST_ACCOUNT_CODE=2-2050
POS_DELIVERY_CHANNELS=gofood,grabfood,shopeefood
POS_DELIVERY_NET_BPS=8000

# App URLs
NEXT_PUBLIC_WEB_URL=http://localhost:3000
NEXT_PUBLIC_SITE_URL=http://localhost:3001
MCP_SERVER_URL=http://localhost:3002
PUBLIC_SITE_TENANT_ID=default

# Node environment
NODE_ENV=development
