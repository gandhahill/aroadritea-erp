{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "baseUrl": ".",
    "outDir": "./dist",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "noEmit": false,
    "declaration": true,
    "paths": {
      "@erp/db": ["../../packages/db/index.ts"],
      "@erp/db/*": ["../../packages/db/*"],
      "@erp/shared": ["../../packages/shared/src/index.ts"],
      "@erp/shared/*": ["../../packages/shared/src/*"],
      "@erp/services": ["../../packages/services/index.ts"],
      "@erp/services/*": ["../../packages/services/src/*"]
    }
  },
  "include": ["src/**/*.ts"],
  "exclude": ["node_modules", "dist"]
}
