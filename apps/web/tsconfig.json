{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "target": "ES2020",
    "lib": [
      "dom",
      "dom.iterable",
      "esnext",
      "webworker"
    ],
    "jsx": "preserve",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "plugins": [
      {
        "name": "next"
      }
    ],
    "paths": {
      "@/*": ["./*"],
      "@erp/db": ["../../packages/db/index.ts"],
      "@erp/db/*": ["../../packages/db/*"],
      "@erp/shared": ["../../packages/shared/src/index.ts"],
      "@erp/shared/*": ["../../packages/shared/src/*"],
      "@erp/services": ["../../packages/services/index.ts"],
      "@erp/services/*": ["../../packages/services/src/*"],
      "@erp/offline": ["../../packages/offline/src/index.ts"],
      "@erp/offline/*": ["../../packages/offline/src/*"]
    },
    "allowJs": true,
    "incremental": true
  },
  "include": [
    "next-env.d.ts",
    "**/*.ts",
    "**/*.tsx",
    ".next/types/**/*.ts"
  ],
  "exclude": [
    "node_modules"
  ]
}
