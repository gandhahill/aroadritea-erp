{
  "name": "@erp/db",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "exports": {
    ".": "./index.ts",
    "./client": "./client.ts",
    "./schema/common": "./schema/common.ts",
    "./schema/auth": "./schema/auth.ts",
    "./schema/accounting": "./schema/accounting.ts",
    "./schema/audit": "./schema/audit.ts",
    "./schema/inventory": "./schema/inventory.ts",
    "./schema/pos": "./schema/pos.ts",
    "./schema/purchasing": "./schema/purchasing.ts",
    "./schema/scheduled-jobs": "./schema/scheduled-jobs.ts",
    "./schema/hr": "./schema/hr.ts",
    "./schema/kitchen": "./schema/kitchen.ts",
    "./schema/cms": "./schema/cms.ts",
    "./schema/member": "./schema/member.ts",
    "./schema/crm": "./schema/crm.ts",
    "./schema/promotion": "./schema/promotion.ts",
    "./schema/correspondence": "./schema/correspondence.ts",
    "./schema/customfield": "./schema/customfield.ts",
    "./schema/workflow": "./schema/workflow.ts",
    "./schema/notification": "./schema/notification.ts",
    "./schema/notifications": "./schema/notifications.ts",
    "./schema/stock-opname": "./schema/stock-opname.ts",
    "./schema/whistleblower": "./schema/whistleblower.ts",
    "./schema/sop": "./schema/sop.ts",
    "./schema/ai": "./schema/ai.ts",
    "./schema/reporting/daily-revenue-adjustments": "./schema/reporting/daily-revenue-adjustments.ts"
  },
  "scripts": {
    "generate": "drizzle-kit generate",
    "migrate": "drizzle-kit migrate",
    "seed": "tsx seed/index.ts",
    "reset": "tsx scripts/reset.ts",
    "reset:migrate:seed": "tsx scripts/reset.ts && drizzle-kit migrate && tsx seed/index.ts",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@erp/shared": "workspace:*",
    "argon2": "^0.44.0",
    "drizzle-orm": "^0.45.2",
    "postgres": "^3.4.9"
  },
  "devDependencies": {
    "drizzle-kit": "^0.28.0",
    "tsx": "^4.0.0",
    "typescript": "^5.5.0"
  }
}
